{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["**", "!!**/dist"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"domains": {
			"react": "recommended"
		},
		"rules": {
			"recommended": true
		}
	},
	"overrides": [
		{
			"includes": ["src/common/app-tour/**"],
			"linter": {
				"rules": {
					"correctness": {
						"noPrivateImports": {
							"level": "error",
							"options": {
								"defaultVisibility": "package"
							}
						}
					}
				}
			}
		},
		{
			"includes": ["src/**", "!src/common/app-tour/**"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"patterns": [
									{
										"group": ["@/common/app-tour/**", "!@/common/app-tour"],
										"message": "app-tour の内部モジュールは import しない。@/common/app-tour から import して。"
									}
								]
							}
						}
					}
				}
			}
		}
	],
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
